{
  "name": "@desktoplab/desktop",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "tsc -b --pretty false",
    "test": "vitest run",
    "smoke": "node scripts/smoke-dispatch.mjs",
    "line-guard": "node scripts/line-guard.mjs",
    "visual:vocabulary-guard": "node scripts/visual-vocabulary-guard.mjs",
    "visual:product-audit": "npm run smoke -- tests/product/visual-product-audit.spec.ts --project=desktop --workers=1",
    "package:check-prereqs": "bash ../../scripts/packaging/check-prereqs.sh",
    "package:dev": "bash ../../scripts/packaging/build-dev.sh",
    "package:macos:release": "bash ../../scripts/packaging/build-macos-release.sh",
    "package:macos:prepare": "bash ../../scripts/packaging/prepare-macos-candidate.sh",
    "package:macos:promote": "bash ../../scripts/packaging/promote-macos-candidate.sh",
    "check": "npm run typecheck && npm run test && npm run line-guard",
    "check:full": "npm run check && npm run smoke:product",
    "smoke:pause": "node -e \"setTimeout(() => {}, 750)\"",
    "smoke:product": "npm run smoke:pause && npm run smoke -- tests/local-api-product.spec.ts --project=desktop && npm run smoke:pause && npm run smoke -- tests/fresh-user-product-flow.spec.ts --project=desktop && npm run smoke:pause && npm run smoke -- tests/packaged-product-launch.spec.ts --project=desktop && npm run smoke:pause && npm run smoke -- tests/product-readiness-no-route-intercepts.spec.ts",
    "product:truth": "npm run typecheck && npm run line-guard && npm run test && npm run smoke:product"
  },
  "dependencies": {
    "@desktoplab/client-sdk": "0.1.0",
    "@tanstack/react-query": "^5.83.0",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.2.6"
  }
}
